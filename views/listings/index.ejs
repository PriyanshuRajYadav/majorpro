<%layout("/layouts/boilerplate")-%>

  <div class="page-heading">
    <div>
      <p class="eyebrow">Explore stays</p>
      <h3>All Listings</h3>
    </div>
    <a class="btn btn-dark" href="/listings/new">Add Listing</a>
  </div>
  <!-- <form method="GET" action="/listings/new">
    <button>Create New</button>
  </form> -->
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 listing-grid">
    <%for(let listing of allListing ){%>
      <a class="listing-link" href="/listings/<%=listing._id%>">
  <div class="card listing-card col" >
  <img src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=800&q=60' %>" class="card-img-top listing-img" alt="<%= listing.title %>">
  <div class="card-body">
    <p class="card-title"><%=listing.title%></p>
    <p class="card-location"><%=listing.location%>, <%=listing.country%></p>
    <p class="card-price">&#8377;<%=listing.price.toLocaleString("en-IN")%> <span>/ night</span></p>
  </div>
</div>
</a>
<%

}%>
  </div>

  

  


